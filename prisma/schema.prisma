generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  avatar       String?
  currency     String        @default("VND")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  transactions Transaction[]
  categories   Category[]
  goals        Goal[]
  budgets      Budget[]
  assets       Asset[]
  transfers    Transfer[]
  notifications Notification[]
  pushSubscriptions PushSubscription[]
  notifSetting      NotifSetting?
}

model Category {
  id           String        @id @default(cuid())
  name         String
  icon         String        @default("💰")
  color        String        @default("#6366f1")
  type         String
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([name, userId])
}

model Transaction {
  id          String   @id @default(cuid())
  amount      Float
  type        String
  note        String   @default("")
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  userId      String
  categoryId  String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id])
}

model Goal {
  id           String    @id @default(cuid())
  name         String
  icon         String    @default("🎯")
  targetAmount Float
  savedAmount  Float     @default(0)
  deadline     DateTime?
  color        String    @default("#10b981")
  status       String    @default("active")
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Budget {
  id         String   @id @default(cuid())
  amount     Float
  month      Int
  year       Int
  userId     String
  categoryId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, categoryId, month, year])
}

model Asset {
  id           String    @id @default(cuid())
  name         String
  type         String    // "financial" | "physical"
  subtype      String?   // "cash" | "bank" | "ewallet" | "device" | "vehicle" | etc.
  purchaseDate DateTime?
  purchasePrice Float    @default(0)
  currentValue Float     @default(0)
  note         String    @default("")
  image        String?
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  transfersFrom Transfer[] @relation("FromAsset")
  transfersTo   Transfer[] @relation("ToAsset")
}

model Transfer {
  id          String   @id @default(cuid())
  amount      Float
  note        String   @default("")
  date        DateTime @default(now())
  fromAssetId String
  toAssetId   String
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromAsset   Asset    @relation("FromAsset", fields: [fromAssetId], references: [id])
  toAsset     Asset    @relation("ToAsset", fields: [toAssetId], references: [id])
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   // "expense_reminder" | "goal" | "budget_warning" | "bill"
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotifSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique
  expenseReminder     Boolean  @default(true)
  expenseReminderTime String   @default("20:00")
  goalReminder        Boolean  @default(true)
  budgetWarning       Boolean  @default(true)
  billReminder        Boolean  @default(false)
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
