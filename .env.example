# Database
DATABASE_URL="postgresql://user:password@host:5432/spendy"
DIRECT_URL="postgresql://user:password@host:5432/spendy"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-run-openssl-rand-base64-32"
NEXTAUTH_URL="https://your-app.onrender.com"

# VAPID Keys for Web Push Notifications
# Generate bằng lệnh: npx web-push generate-vapid-keys
# Sau đó copy vào đây:
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:your-email@example.com"
